# ==============================
# Platform-specific / local config files
# (files that often contain Platform / dart:io / web checks)
# ==============================
lib/config/*platform*.dart
lib/config/local_config.dart
lib/utils/*platform*.dart
lib/services/*platform*.dart
lib/utils/platform_utils.dart
lib/services/platform_service.dart
lib/main_desktop.dart
lib/main_web.dart
*platform*.dart
*Platform*.dart

# ==============================
# Build Directory
# Ignore everything inside build except web build (needed for deployment)
# ==============================
/build/*
!/build/
!/build/web/
!/build/web/**

# ==============================
# Symbolication / Obfuscation
# ==============================
app.*.symbols
app.*.map.json

# ==============================
# Android
# ==============================
android/.gradle/
android/local.properties
android/gradlew
android/gradlew.bat
/android/app/debug
/android/app/profile
/android/app/release

# ==============================
# iOS
# ==============================
ios/Flutter/flutter_export_environment.sh
ios/Flutter/Generated.xcconfig
ios/Runner/GeneratedPluginRegistrant.*

# ==============================
# Web (ignore generated web artifacts that are not source code)
# ==============================
web/build/
web/flutter_service_worker.js
web/index.html.bak
web/icons/  # if you generate icons locally

# ==============================
# macOS / Desktop
# ==============================
macos/Flutter/ephemeral/
macos/Runner/GeneratedPluginRegistrant.*

# ==============================
# Temporary / test files
# ==============================
*.tmp
*.bak
test/*.log